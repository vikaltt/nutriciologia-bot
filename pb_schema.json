[
  {
    "name": "profiles",
    "type": "base",
    "schema": [
      { "name": "role", "type": "select", "options": { "values": ["client", "nutritionist"] } },
      { "name": "telegram_id", "type": "text", "required": true, "unique": true },
      { "name": "full_name", "type": "text" }
    ]
  },
  {
    "name": "surveys",
    "type": "base",
    "schema": [
      { "name": "client_id", "type": "relation", "options": { "collectionId": "profiles", "maxSelect": 1 } },
      { "name": "goals", "type": "text" },
      { "name": "restrictions", "type": "text" },
      { "name": "budget", "type": "text" },
      { "name": "age", "type": "number" },
      { "name": "weight", "type": "number" },
      { "name": "height", "type": "number" },
      { "name": "status", "type": "select", "options": { "values": ["new", "reviewed"] } }
    ]
  },
  {
    "name": "nutrition_plans",
    "type": "base",
    "schema": [
      { "name": "client_id", "type": "relation", "options": { "collectionId": "profiles" } },
      { "name": "plan_data", "type": "json", "required": true },
      { "name": "status", "type": "select", "options": { "values": ["draft", "active"] } }
    ]
  },
  {
    "name": "check_ins",
    "type": "base",
    "schema": [
      { "name": "client_id", "type": "relation", "options": { "collectionId": "profiles" } },
      { "name": "water_ml", "type": "number" },
      { "name": "weight", "type": "number" },
      { "name": "food_log", "type": "text" },
      { "name": "date", "type": "date" }
    ]
  }
]
